+def _cached_chunk_indices(cu_seqlens, chunk_size):
+    """tolist()+prepare_chunk_indices computed once/step, cached on the cu_seqlens tensor object
+    (same object across all GDN layers; fresh tensor next step -> auto-invalidates). Avoids the
+    ~Nx redundant .tolist() D2H syncs/step that the profile showed cost ~3s/step."""
+    if cu_seqlens is None:
+        return None, None
+    cached = getattr(cu_seqlens, "_gdn_ci_cache", None)
+    if cached is not None and cached[0] == chunk_size:
+        return cached[1], cached[2]
+    cu_list = cu_seqlens.tolist()
+    chunk_indices = prepare_chunk_indices(cu_list, chunk_size)
+    try:
+        cu_seqlens._gdn_ci_cache = (chunk_size, cu_list, chunk_indices)
+    except Exception:
+        pass
+    return cu_list, chunk_indices
+
